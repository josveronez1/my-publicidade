# --- Front-end (Vite) — obrigatório para npm run dev ---
# Anon key: Supabase → Project Settings → API → Project API keys (anon, public)
VITE_SUPABASE_URL=https://czfuzguxcjjgvuvlmhnh.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Opcional: sem isso, o Media Kit mostra lista + link Google Maps por ponto (mapa Mapbox fica desligado).
VITE_MAPBOX_TOKEN=

# --- Postgres direto (opcional) — migrações com psql, Drizzle, etc. ---
# NUNCA commite a senha. Use só no .env local (já está no .gitignore).
# Formato direto (host direto pode exigir IPv6; em rede só IPv4 use o Session Pooler no dashboard):
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.czfuzguxcjjgvuvlmhnh.supabase.co:5432/postgres
#
# Supabase → Project Settings → Database → Connection string → Session pooler (IPv4).
